# ── Local backend ───────────────────────────────────────────────────────────
APP_ENV=dev
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./watchdog.db
TOKEN_EXPIRE_DAYS=30

# ── AI ──────────────────────────────────────────────────────────────────────
# Anthropic key for the LangChain/LangGraph code analyzer
ANTHROPIC_API_KEY=

# ── Whop (subscription gating) ──────────────────────────────────────────────
WHOP_API_KEY=
WHOP_PRODUCT_URL=
WHOP_PRODUCT_ID=

# ── Cloud relay connector (sdk/wd_cloud.py) ─────────────────────────────────
# Used to log this desktop install in to watchdogbot.cloud
CLOUD_EMAIL=
CLOUD_PASSWORD=
CLOUD_API_URL=https://watchdogbot.cloud

# ── Local backend address (the cloud relay tunnels HTTP here) ──────────────
LOCAL_API_URL=http://localhost:8000
LOCAL_API_USER=admin
LOCAL_API_PASS=admin

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
